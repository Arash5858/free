def organize_files(directory_path):
    """
    Organizes files in the given directory by their file extensions.
    Each extension will have its own folder.
    """

    if not os.path.exists(directory_path):
        print("Directory does not exist.")
        return
Organizes files in the given directory by their file extensions.
    Each extension will have its own folder.
    """
    for filename in os.listdir(directory_path):
        file_path = os.path.join(directory_path, filename)

    if not os.path.exists(directory_path):
        print("Directory does not exist.")
        return
        if os.path.isfile(file_path):
            file_extension = filename.split('.')[-1].lower()

            target_folder = os.path.join(directory_path, file_extension)
            os.makedirs(target_folder, exist_ok=True)

            shutil.move(file_path, os.path.join(target_folder, filename))

    print("Files organized successfully.")

if __name__ == "__main__":
    path = input("Enter the directory path to organize: ")
    organize_files(path)
